LLM_MODEL=

# SITE
NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_SITE_NAME=RPA公共知识库
NEXT_PUBLIC_SITE_DESCRIPTION=RPA制品公共知识库

# GIT
NEXT_PUBLIC_GIT_REPO_WEB_URL=https://codeup.aliyun.com/yuce-tech/rpa/rpa-products-docs
